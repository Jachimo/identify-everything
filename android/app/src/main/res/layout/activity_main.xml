<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <EditText
        android:id="@+id/guidInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Enter GUID (e.g., 3k7x9b_p1j4_nv6d)"
        android:inputType="textUri"
        style="@style/Widget.AppCompat.EditText"
        app:layout_constraintBottom_toBottomOf="@id/showDetailsButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/showDetailsButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="View Item Details"
        android:layout_marginTop="16dp"
        style="@style/Widget.AppCompat.Button.Colored"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/guidInput" />

</androidx.constraintlayout.widget.ConstraintLayout>
